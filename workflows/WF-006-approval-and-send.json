    {
      "parameters": {
        "jsCode": "const approvalId = String($('Process approval').all()[0].json['Approval ID'] || '').trim();\nif (!approvalId) {\n  throw new Error('Please provide an Approval ID.');\n}\nconst rows = $('Read approvals').all().map(i => i.json);\nconst approval = rows.find(r => String(r.id).trim() === approvalId);\nif (!approval) {\n  throw new Error('Approval ID not found: ' + approvalId);\n}\nif (String(approval.decision || '').trim().toLowerCase() !== 'pending') {\n  throw new Error('Approval ' + approvalId + ' is already decided (' + approval.decision + '). Refusing to process again.');\n}\nreturn [{ json: approval }];"
      },
      "id": "f6a10003-3333-4f60-9a05-500000000003",
      "name": "Find approval",
      "type": "n8n-nodes-base.code",
