    {
      "parameters": {
        "jsCode": "const form = $('Process approval').all()[0].json;\nconst approval = $('Find approval').all()[0].json;\nconst matches = $('Read buyer_matches').all().map(i => i.json);\n\nconst decisionInput = String(form['Decision'] || '').trim();\nconst editedMsg = String(form['Edited message'] || '').trim();\nconst reasonInput = String(form['Reason'] || '').trim();\nconst approver = String(form['Approver name'] || '').trim() || 'manager_amina';\nconst ts = $now.toISO();\n\nconst original = String(approval.original_content || '');\nconst approvalType = String(approval.approval_type || '');\nconst isOutreach = approvalType === 'buyer_outreach';\n\nlet new_decision, send, final_content, reason;\nswitch (decisionInput) {\n  case 'approve':\n    new_decision = 'approved'; send = true; final_content = original; reason = reasonInput; break;\n  case 'edit_and_approve':\n    if (!editedMsg) throw new Error('Edited message is required for edit_and_approve.');\n    new_decision = 'edited'; send = true; final_content = editedMsg; reason = reasonInput; break;\n  case 'reject':\n    if (!reasonInput) throw new Error('A reason is required to reject.');\n    new_decision = 'rejected'; send = false; final_content = ''; reason = reasonInput; break;\n  case 'request_buyer_verification':\n    new_decision = 'needs_verification'; send = false; final_content = ''; reason = reasonInput || 'Buyer verification requested before outreach'; break;\n  case 'request_farmer_confirmation':\n    new_decision = 'needs_verification'; send = false; final_content = ''; reason = reasonInput || 'Farmer confirmation requested'; break;\n  default:\n    throw new Error('Unknown decision: ' + decisionInput);\n}\n\nlet produce_lot_id = '', buyer_id = '', deal_id = '';\nif (isOutreach) {\n  const match = matches.find(m => String(m.id).trim() === String(approval.related_entity_id).trim());\n  if (match) {\n    produce_lot_id = match.produce_lot_id || '';\n    buyer_id = match.buyer_id || '';\n    deal_id = 'deal_' + produce_lot_id + '_' + buyer_id;\n  } else {\n    deal_id = 'deal_' + (approval.related_entity_id || 'unknown');\n  }\n}\n\nconst send_subject = isOutreach\n  ? ('FarmGateIQ — Approved outreach re: lot ' + produce_lot_id + ' (buyer ' + buyer_id + ')')\n  : 'FarmGateIQ — Approved farmer price update';\n\nreturn [{ json: {\n  approval_id: approval.id,\n  approval_type: approvalType,\n  is_outreach: isOutreach ? 'TRUE' : 'FALSE',\n  new_decision: new_decision,\n  approved_by: approver,\n  final_content: final_content,\n  reason: reason,\n  decided_at: ts,\n  send: send ? 'TRUE' : 'FALSE',\n  produce_lot_id: produce_lot_id,\n  buyer_id: buyer_id,\n  deal_id: deal_id,\n  send_subject: send_subject\n}}];"
      },
