    {
      "parameters": {
        "jsCode": "const item = $input.all()[0].json;\n\nconst errors = [];\nif (!item['Buyer name'] || !String(item['Buyer name']).trim()) errors.push('Buyer name');\nif (!item['Commodity interests'] || !String(item['Commodity interests']).trim()) errors.push('Commodity interests');\nconst hasPhone = !!(item['Phone'] && String(item['Phone']).trim());\nconst hasEmail = !!(item['Email'] && String(item['Email']).trim());\nif (!hasPhone && !hasEmail) errors.push('Phone or Email (at least one contact method)');\n\nif (errors.length) {\n  throw new Error('Missing required fields: ' + errors.join(', '));\n}\n\nconst map = { corn: 'maize', masara: 'maize', 'yellow maize': 'maize', 'white maize': 'maize' };\nconst interests = String(item['Commodity interests']).toLowerCase().split(',').map(s => s.trim()).filter(Boolean).map(c => map[c] || c);\nconst norm_interests = [...new Set(interests)].join(', ');\n\nreturn [{ json: Object.assign({}, item, { norm_interests: norm_interests }) }];"
      },
