{
  "name": "WF-004 Buyer Profile Intake",
  "nodes": [
    {
      "parameters": {
        "formTitle": "FarmGateIQ \u2014 Buyer Profile",
        "formDescription": "Register a buyer profile. Trust status is set by the cooperative manager, not automatically. Privacy: contact details (name, phone, email) are stored only to enable approved produce outreach and are not shared without consent. Phone numbers are kept out of system logs. (Nigeria Data Protection Act, 2023.)",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Buyer name",
              "placeholder": "e.g. KadFeed Processing Ltd",
              "requiredField": true
            },
            {
              "fieldLabel": "Contact name",
              "placeholder": "e.g. Emeka Okafor"
            },
            {
              "fieldLabel": "Phone",
              "placeholder": "e.g. +234 000 0000 001"
            },
            {
              "fieldLabel": "Email",
              "fieldType": "email",
              "placeholder": "e.g. buyer@example.com"
            },
            {
              "fieldLabel": "Commodity interests",
              "placeholder": "e.g. maize, soybeans",
              "requiredField": true
            },
            {
              "fieldLabel": "Min quantity",
              "fieldType": "number",
              "placeholder": "e.g. 50"
            },
            {
              "fieldLabel": "Max quantity",
              "fieldType": "number",
              "placeholder": "e.g. 300"
            },
            {
              "fieldLabel": "Preferred unit",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "bag"
                  },
                  {
                    "option": "kg"
                  },
                  {
                    "option": "tonne"
                  }
                ]
              },
              "requiredField": true
            },
            {
              "fieldLabel": "Preferred locations",
              "placeholder": "e.g. Kaduna, Zaria, Kano"
            },
            {
              "fieldLabel": "Quality requirements",
              "placeholder": "e.g. dry low moisture bagged"
            },
            {
              "fieldLabel": "Payment terms",
              "placeholder": "e.g. payment after inspection"
            },
            {
              "fieldLabel": "Trust status",
              "fieldType": "dropdown",
              "fieldOptions": {
                "values": [
                  {
                    "option": "unverified"
                  },
                  {
                    "option": "verified"
                  },
                  {
                    "option": "preferred"
                  },
                  {
                    "option": "blocked"
                  }
                ]
              },
              "requiredField": true
            },
            {
              "fieldLabel": "Notes",
              "fieldType": "textarea",
              "placeholder": "e.g. Reliable payment history. Prefers Zaria pickup."
            },
            {
              "fieldLabel": "Consent",
              "fieldType": "checkbox",
              "fieldOptions": {
                "values": [
                  {
                    "option": "I confirm this buyer has agreed to be contacted by the cooperative for produce outreach, in line with the privacy notice above."
                  }
                ]
              },
              "requiredField": true
            }
          ]
        },
        "options": {}
      },
      "id": "c3a2b1d0-1111-4c4d-9e03-300000000001",
      "name": "On buyer profile submission",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.5,
