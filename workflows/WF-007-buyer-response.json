  "name": "WF-007 Buyer Response",
  "nodes": [
    {
      "parameters": {
        "formTitle": "FarmGateIQ \u2014 Log Buyer Response",
        "formDescription": "Record a buyer's reply. The system classifies it and updates the deal tracker. It does NOT reply to the buyer \u2014 any reply goes through approval.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Buyer ID",
              "placeholder": "e.g. buyer_001",
              "requiredField": true
            },
            {
              "fieldLabel": "Produce lot ID",
              "placeholder": "e.g. lot_001",
              "requiredField": true
            },
            {
              "fieldLabel": "Response text",
              "fieldType": "textarea",
              "placeholder": "Paste the buyer's reply here.",
              "requiredField": true
            }
          ]
        },
        "options": {}
      },
      "id": "a7b20001-1111-4a70-9b06-600000000001",
      "name": "Log buyer response",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.5,
      "position": [
        -1760,
        420
      ],
      "webhookId": "f3a4b5c6-9a02-4e3b-9cee-001112030413"
    },
    {
      "parameters": {
        "jsCode": "const item = $input.all()[0].json;\nconst buyerId = String(item['Buyer ID'] || '').trim();\nconst lotId = String(item['Produce lot ID'] || '').trim();\nconst text = String(item['Response text'] || '').trim();\nif (!buyerId) throw new Error('Buyer ID is required.');\nif (!lotId) throw new Error('Produce lot ID is required.');\nif (!text) throw new Error('Response text is required.');\n\nconst parts = [];\nparts.push('You are classifying a buyer reply to a Nigerian farmer cooperative maize outreach.');\nparts.push('Classify the reply into exactly ONE status from this list: interested, counter_offer, needs_information, rejected, suspicious, irrelevant.');\nparts.push('Definitions: interested = wants to proceed, inspect, or buy; counter_offer = proposes a different price or terms; needs_information = asks for more details before deciding; rejected = declines; suspicious = unsafe or scam-like terms (for example, asking for goods to be sent before any payment); irrelevant = not about this deal.');\nparts.push('Then write a one-sentence summary and a recommended NEXT ACTION for the cooperative MANAGER (not a reply to the buyer).');\nparts.push('Do NOT draft a message to the buyer - any reply to a buyer must go through separate human approval.');\nparts.push('');\nparts.push('BUYER ID: ' + buyerId);\nparts.push('LOT ID: ' + lotId);\nparts.push('REPLY TEXT:');\nparts.push(text);\nparts.push('');\nparts.push('Return ONLY a JSON object, no markdown fences:');\nparts.push('{ \"classified_status\": \"...\", \"summary\": \"...\", \"recommended_next_action\": \"...\", \"suspicious\": true }');\n\nreturn [{ json: Object.assign({}, item, { prompt: parts.join('\\n'), buyer_id: buyerId, lot_id: lotId, response_text: text }) }];"
      },
