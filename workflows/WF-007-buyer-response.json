    {
      "parameters": {
        "jsCode": "const item = $input.all()[0].json;\nconst src = $('Build classify prompt').all()[0].json;\nconst validStatuses = ['interested', 'counter_offer', 'needs_information', 'rejected', 'suspicious', 'irrelevant'];\n\nlet parsed;\ntry {\n  const t = (item.text || item.output || '').replace(/```json\\s*/gi, '').replace(/```\\s*/g, '').trim();\n  parsed = JSON.parse(t);\n} catch (e) {\n  parsed = { classified_status: 'needs_information', summary: 'Could not parse classification: ' + e.message, recommended_next_action: 'Manager to review the raw reply manually.', suspicious: false };\n}\n\nlet status = String(parsed.classified_status || '').toLowerCase().trim();\nif (!validStatuses.includes(status)) status = 'needs_information';\n\nconst statusMap = { interested: 'interested', counter_offer: 'negotiating', needs_information: 'negotiating', rejected: 'closed_lost', suspicious: 'contacted', irrelevant: 'contacted' };\nconst deal_status = statusMap[status] || 'contacted';\nconst suspicious = (parsed.suspicious === true || status === 'suspicious') ? 'TRUE' : 'FALSE';\n\nreturn [{ json: {\n  buyer_id: src.buyer_id,\n  lot_id: src.lot_id,\n  response_text: src.response_text,\n  classified_status: status,\n  summary: parsed.summary || '',\n  recommended_next_action: parsed.recommended_next_action || 'Manager to review.',\n  suspicious: suspicious,\n  deal_status: deal_status,\n  deal_id: 'deal_' + src.lot_id + '_' + src.buyer_id\n}}];"
      },
