      "id": "a7b20004-4444-4a70-9b06-600000000004",
      "name": "Claude",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.5,
      "position": [
        -1200,
        640
      ],
      "credentials": {
