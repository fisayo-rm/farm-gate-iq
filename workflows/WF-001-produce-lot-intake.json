{
  "name": "WF-001 Produce Lot Intake",
  "nodes": [
    {
      "parameters": {
        "formTitle": "FarmGateIQ — Produce Lot Intake",
        "formDescription": "Enter your produce details in the free text box, or fill in the structured fields below — or both. Privacy: the details you submit (including the member name) are used only by the cooperative to register produce and match it to buyers. They are not shared with third parties without consent. (Nigeria Data Protection Act, 2023.)",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Member name",
              "placeholder": "e.g. Aminu Musa",
              "requiredField": true
            },
            {
              "fieldLabel": "Free text submission",
              "fieldType": "textarea",
              "placeholder": "e.g. I have 120 bags of dry maize in Zaria available from 15 June. Asking 48000 per bag."
            },
            {
              "fieldLabel": "Commodity",
              "placeholder": "e.g. maize, corn, masara"
            },
            {
              "fieldLabel": "Quantity",
              "fieldType": "number",
              "placeholder": "e.g. 120"
            },
            {
              "fieldLabel": "Unit",
              "placeholder": "e.g. bag, sack, kg"
            },
            {
              "fieldLabel": "Location",
              "placeholder": "e.g. Zaria, Kaduna"
            },
            {
              "fieldLabel": "Availability date",
              "fieldType": "date"
            },
            {
              "fieldLabel": "Asking price",
              "fieldType": "number",
              "placeholder": "e.g. 48000"
            },
            {
              "fieldLabel": "Quality notes",
              "fieldType": "textarea",
              "placeholder": "e.g. dry, bagged, moisture below 13%"
            },
            {
              "fieldLabel": "Consent",
              "fieldType": "checkbox",
              "fieldOptions": {
                "values": [
                  { "option": "I consent to these details being used by the cooperative to register produce and match it to buyers, in line with the privacy notice above." }
                ]
              },
              "requiredField": true
            }
          ]
        },
        "options": {}
      },
      "id": "fc43d097-02d0-4ced-ad48-5771e138e6fe",
      "name": "On form submission",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2.5,
