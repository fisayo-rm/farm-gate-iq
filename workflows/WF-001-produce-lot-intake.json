    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst item = items[0].json;\nconst formItem = $('On form submission').all()[0].json;\n\nlet llm;\ntry {\n  const text = (item.text || item.output || '').replace(/```json\\s*/gi, '').replace(/```\\s*/g, '').trim();\n  llm = JSON.parse(text);\n} catch(e) {\n  llm = {\n    commodity: formItem['Commodity'] || '',\n    quantity: parseFloat(formItem['Quantity']) || null,\n    unit: formItem['Unit'] || '',\n    location: formItem['Location'] || '',\n    availability_date: '',\n    quality_notes: formItem['Quality notes'] || '',\n    asking_price: parseFloat(formItem['Asking price']) || null,\n    asking_price_unit: 'per bag',\n    confidence: 'low',\n    needs_review: true,\n    missing_fields: [],\n    normalization_notes: 'LLM parse error: ' + e.message\n  };\n}\n\nconst rawLower = (formItem['Commodity'] || '').toLowerCase().trim();\nconst commodityLookup = { corn: 'maize', masara: 'maize', 'yellow maize': 'maize', 'white maize': 'maize' };\nif (commodityLookup[rawLower]) llm.commodity = commodityLookup[rawLower];\n\nconst unitLower = (llm.unit || '').toLowerCase().trim();\nif (unitLower === 'sack' || unitLower === 'sacks' || unitLower === 'bags') llm.unit = 'bag';\n\nconst scoreMap = { high: 0.90, medium: 0.70, low: 0.35 };\nconst confidenceScore = scoreMap[llm.confidence] || 0.35;\nconst needsReview = llm.needs_review === true || llm.confidence === 'low';\n\nreturn [{ json: {\n  member_name: formItem['Member name'],\n  raw_commodity: formItem['Commodity'] || llm.raw_commodity || '',\n  raw_quantity_text: (formItem['Quantity'] && parseFloat(formItem['Quantity']) > 0)\n    ? (String(formItem['Quantity']) + ' ' + String(formItem['Unit'] || '')).trim()\n    : (llm.raw_quantity_text || (llm.quantity != null ? String(llm.quantity) + ' ' + String(llm.unit || '') : '')).trim(),\n  commodity: llm.commodity || '',\n  quantity: llm.quantity,\n  unit: llm.unit || '',\n  location: llm.location || formItem['Location'] || '',\n  availability_date: llm.availability_date || '',\n  quality_notes: llm.quality_notes || formItem['Quality notes'] || '',\n  asking_price: llm.asking_price,\n  asking_price_unit: llm.asking_price_unit || 'per bag',\n  confidence: llm.confidence || 'low',\n  confidence_score: confidenceScore,\n  needs_review: needsReview ? 'TRUE' : 'FALSE',\n  normalization_notes: llm.normalization_notes || '',\n  missing_fields: (llm.missing_fields || []).join(', ')\n}}];"
      },
