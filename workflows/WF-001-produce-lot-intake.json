    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst item = items[0].json;\n\nif (!item['Member name'] || String(item['Member name']).trim() === '') {\n  throw new Error('Missing required field: Member name');\n}\n\nconst hasFreeText = !!(item['Free text submission'] && String(item['Free text submission']).trim());\nconst hasCommodity = !!(item['Commodity'] && String(item['Commodity']).trim());\n\nif (!hasFreeText && !hasCommodity) {\n  throw new Error('Please provide either a free text description or fill in the Commodity field.');\n}\n\nconst parts = [];\nparts.push('You are processing a produce lot submission for a Nigerian farmer cooperative in Kaduna State.');\nparts.push('The field officer may have provided a free text description, structured fields, or both.');\nparts.push('Extract and normalize everything available into a JSON object.');\nparts.push('');\nparts.push('FREE TEXT (primary input if provided):');\nparts.push(item['Free text submission'] || 'none');\nparts.push('');\nparts.push('STRUCTURED FIELDS (may be empty — use to supplement or confirm free text):');\nparts.push('Commodity: ' + (item['Commodity'] || 'not provided'));\nparts.push('Quantity: ' + (item['Quantity'] || 'not provided') + ' ' + (item['Unit'] || ''));\nparts.push('Location: ' + (item['Location'] || 'not provided'));\nparts.push('Availability date: ' + (item['Availability date'] || 'not provided'));\nparts.push('Asking price: ' + (item['Asking price'] || 'not provided') + ' per bag');\nparts.push('Quality notes: ' + (item['Quality notes'] || 'not provided'));\nparts.push('');\nparts.push('NORMALIZATION RULES:');\nparts.push('1. Commodity: corn, masara, yellow maize, white maize -> maize. Keep unknown crops as-is.');\nparts.push('2. Unit: sack/sacks -> bag. For mudu or paint bucket: keep original but set needs_review true.');\nparts.push('3. Location: if the LGA is in Kaduna State (Zaria, Sabon Gari, Giwa, Makarfi, Ikara, Kubau), append a comma and Kaduna to the location.');\nparts.push('4. Date: convert to YYYY-MM-DD. Assume year 2026 if year not stated.');\nparts.push('5. Confidence: high if all fields extracted cleanly; medium if minor normalizations or one field missing; low if key fields (location, quantity, commodity) are missing.');\nparts.push('6. Set needs_review to true if confidence is low, unit cannot be normalized, or price is below 30000 or above 80000.');\nparts.push('7. List any fields you could not extract in missing_fields.');\nparts.push('');\nparts.push('REQUIRED OUTPUT FORMAT:');\nparts.push('Return ONLY a valid JSON object with no explanation and no markdown code fences.');\nparts.push('Include these fields: commodity (string), raw_commodity (string — the exact commodity name as it appeared in the input before normalization, e.g. \"corn\" not \"maize\"; if already standard write the same as commodity), raw_quantity_text (string — the quantity and unit exactly as written in the input, e.g. \"120 bags\", \"about 80 sacks\", \"50 bags\"), quantity (number or null), unit (string), location (string),');\nparts.push('availability_date (YYYY-MM-DD or empty string), quality_notes (string),');\nparts.push('asking_price (number or null), asking_price_unit (string, default per bag), confidence (high or medium or low),');\nparts.push('needs_review (boolean), missing_fields (array of strings), normalization_notes (string).');\n\nconst prompt = parts.join('\\n');\n\nreturn [{ json: Object.assign({}, item, { prompt: prompt }) }];"
      },
